# ===== GitHub =====
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# ===== LLM 配置（用于分析和文案生成）=====
LLM_API_KEY=sk-xxxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ===== 图片生成 API 配置（OpenAI 兼容协议，可指向任意服务商）=====
IMAGE_API_KEY=sk-xxxx
IMAGE_BASE_URL=https://api.siliconflow.cn/v1
IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
IMAGE_SIZE=1024x1024
IMAGE_STYLE=flat illustration, tech style, minimalist,

# ===== 评分权重 =====
SCORE_WEIGHT_NOVELTY=0.3
SCORE_WEIGHT_PRACTICALITY=0.3
SCORE_WEIGHT_CONTENT_FIT=0.25
SCORE_WEIGHT_EASE=0.15

# ===== TopK 配置 =====
TOPK_SIZE=20
PRESENT_TOP_N=3
